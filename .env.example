# Ollama Endpunkte
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_CLOUD_URL=https://api.ollama.com

# Modell-Konfiguration
MODEL_LOCAL=mistral
MODEL_CLOUD=mistral-large-2512
MODEL_VISION=moondream
MODEL_EMBED_LOCAL=nomic-embed-text
MODEL_EMBED_CLOUD=mistral-embed

# ChromaDB Pfade (Kann auch auf NAS-Netzlaufwerke verweisen, z.B. Z:/nsi_rag/chroma_local)
CHROMA_LOCAL_PATH=data/chroma_local
CHROMA_CLOUD_PATH=data/chroma_cloud

# SearXNG
SEARXNG_URL=http://localhost:8080
SEARXNG_TIMEOUT=10

# Advanced RAG Configurations
RAG_HYBRID_SEARCH_ENABLED=true
RAG_RERANKING_ENABLED=true
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
HYBRID_SEARCH_SEMANTIC_WEIGHT=0.7

# Freigegebene Read-only-Quellordner für Nachtjobs.
# Mehrere Einträge mit Semikolon trennen. Beispiele:
# ARGUS_NAS_ROOTS=wissen=Z:/Firmenwissen;projekte=//NAS/Projekte
ARGUS_NAS_ROOTS=

# Uhrzeit des täglichen Nachtjobs (24h-Format, Default: 02:00)
NIGHT_SCHEDULER_HOUR=2
NIGHT_SCHEDULER_MINUTE=0

# Minuten ohne Maus/Tastatur bis Ingestion startet (Default: 15)
IDLE_THRESHOLD_MINUTES=15

# Prüfintervall in Sekunden (Default: 60)
IDLE_CHECK_INTERVAL_SECONDS=60

# Status Mail SMTP Konfiguration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Argus RAG <noreply@rh-automation-dresden.de>
SMTP_TO=code@rh-automation-dresden.de
SMTP_STARTTLS=true

# Uhrzeiten für Status-Mail (24h, kommagetrennt)
STATUS_MAIL_TIMES=10:00,16:00
